---
import Base from '../../hubs/privacy0/layouts/Base.astro';
import Header from '../../hubs/privacy0/components/Header.astro';
import Footer from '../../hubs/privacy0/components/Footer.astro';
import ToolLayout from '../../hubs/privacy0/components/ToolLayout.astro';
---
<Base
  title="Password Generator (strong, random) · privacy0"
  description="Generate cryptographically strong random passwords in your browser, with a live entropy estimate. Nothing is uploaded or stored."
>
  <Header />
  <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-8">
    <ToolLayout name="Password Generator" trust="Passwords are made with crypto.getRandomValues, locally. Nothing is generated on a server, logged, or stored.">
      <div slot="explainer">
        <p class="mb-2">Each password is drawn from your selected character sets using the browser's cryptographically secure random generator (<code>crypto.getRandomValues</code>) with rejection sampling, so there is no modulo bias.</p>
        <p>The entropy estimate is <code>length × log₂(pool size)</code> — a measure of how many guesses an attacker needs. Aim for 80+ bits for anything important. Nothing is uploaded; refresh and it's gone.</p>
      </div>

      <div class="max-w-2xl space-y-6">
        <div class="rounded border border-rule bg-raised p-4">
          <div class="flex items-center gap-2">
            <input id="pw-output" type="text" readonly class="flex-1 bg-bg border border-rule rounded px-3 py-2 text-sm font-mono text-ink focus:outline-none select-all" />
            <button id="pw-copy" class="btn-secondary">Copy</button>
            <button id="pw-regen" class="btn" aria-label="Regenerate">↻</button>
          </div>
          <div class="mt-3">
            <div class="h-1.5 w-full bg-bg rounded-full overflow-hidden">
              <div id="pw-meter-bar" class="h-full rounded-full transition-all" style="width:0%"></div>
            </div>
            <div class="flex items-center justify-between mt-1.5">
              <span id="pw-meter-label" class="text-xs font-mono"></span>
              <span id="pw-entropy" class="text-xs font-mono text-muted"></span>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div>
            <div class="flex items-center justify-between">
              <label for="pw-length" class="label">Length</label>
              <span id="pw-length-val" class="text-sm font-mono text-accent">20</span>
            </div>
            <input id="pw-length" type="range" min="6" max="64" value="20" class="w-full accent-accent mt-2" />
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
            <label class="flex items-center gap-2 text-sm text-ink cursor-pointer"><input id="pw-set-lower" type="checkbox" checked class="accent-accent" /> a-z</label>
            <label class="flex items-center gap-2 text-sm text-ink cursor-pointer"><input id="pw-set-upper" type="checkbox" checked class="accent-accent" /> A-Z</label>
            <label class="flex items-center gap-2 text-sm text-ink cursor-pointer"><input id="pw-set-digits" type="checkbox" checked class="accent-accent" /> 0-9</label>
            <label class="flex items-center gap-2 text-sm text-ink cursor-pointer"><input id="pw-set-symbols" type="checkbox" checked class="accent-accent" /> !@#$</label>
          </div>
          <label class="flex items-center gap-2 text-sm text-muted cursor-pointer"><input id="pw-no-ambiguous" type="checkbox" class="accent-accent" /> Exclude ambiguous characters (O 0 l 1 I …)</label>
        </div>
      </div>
    </ToolLayout>
  </main>
  <Footer />
</Base>
<script>
  import { initPassword } from '../../hubs/privacy0/scripts/tools/password';
  initPassword();
</script>
