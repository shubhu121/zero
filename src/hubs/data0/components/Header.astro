---
// data0 grew from a single SQL workbench into a small hub: the workbench plus a
// set of client-side data converters. The sub-nav surfaces them all.
const tools = [
  { href: '/data0', label: 'workbench' },
  { href: '/data0/csv-json', label: 'csv ⇄ json' },
  { href: '/data0/yaml-json', label: 'yaml ⇄ json' },
  { href: '/data0/sql-format', label: 'sql format' },
  { href: '/data0/markdown-table', label: 'md table' },
  { href: '/data0/base', label: 'base' },
  { href: '/data0/chart', label: 'chart' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="suite-header border-b border-rule">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 pb-3 flex items-baseline justify-between gap-4">
    <a href="/data0" class="display text-2xl tracking-tight">data<span class="text-accent">0</span></a>
    <div class="flex items-center gap-5">
      <button id="theme-toggle" class="label hover:text-ink" aria-label="Toggle theme">◐ theme</button>
      <a href="https://github.com/shubhu121/zero" class="label hover:text-ink" rel="noopener">github ↗</a>
      <a href="https://github.com/sponsors/shubhu121" class="label hover:text-accent" rel="noopener">♡ sponsor</a>
    </div>
  </div>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 pb-3 overflow-x-auto" aria-label="Tools">
    <div class="flex gap-5 min-w-max">
      {tools.map((t) => (
        <a href={t.href}
          aria-current={path === t.href ? 'page' : undefined}
          class={`label hover:text-ink ${path === t.href ? 'text-accent underline underline-offset-4' : ''}`}>
          {t.label}
        </a>
      ))}
    </div>
  </nav>
</header>
<script>
  import { initThemeToggle } from '../scripts/theme';
  initThemeToggle(document.getElementById('theme-toggle')!);
</script>
