---
import Base from '../../hubs/media0/layouts/Base.astro';
import Header from '../../hubs/media0/components/Header.astro';
import Footer from '../../hubs/media0/components/Footer.astro';
import MediaTool from '../../hubs/media0/components/MediaTool.astro';
---
<Base
  title="Convert Video & Audio Online — MP4, WebM, MP3, WAV. No upload | media0"
  description="Convert video and audio between MP4, WebM, MP3 and WAV entirely in your browser. FFmpeg compiled to WebAssembly — your file is never uploaded."
>
  <Header />
  <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-8">
    <MediaTool name="convert" runLabel="Convert">
      <Fragment slot="options">
        <label class="block max-w-xs">
          <span class="label">output format</span>
          <select id="fmt" class="block mt-1 w-full bg-bg border border-rule rounded px-3 py-2 text-sm">
            <option value="mp4">MP4 — H.264 video</option>
            <option value="webm">WebM — VP9 video</option>
            <option value="mp3">MP3 — audio only</option>
            <option value="wav">WAV — audio only</option>
          </select>
        </label>
        <div id="fmt-note" class="label mt-2 normal-case tracking-normal"></div>
      </Fragment>
      <Fragment slot="explainer">
        Converts in-browser with FFmpeg.wasm. Large or sensitive files never touch a server — open
        DevTools → Network and watch: there are no uploads.
      </Fragment>
    </MediaTool>
  </main>
  <Footer />
</Base>
<script>import '../../hubs/media0/scripts/tools/convert';</script>
