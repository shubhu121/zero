---
interface Props { name: string; trust?: string; }
const { name, trust = 'Files are processed by FFmpeg & Whisper compiled to WebAssembly, in this tab — nothing is uploaded, ever. Verify: DevTools → Network.' } = Astro.props;
---
<div class="tool-layout fade-in">
  <h1 class="text-3xl sm:text-4xl tracking-tight">{name}</h1>
  <p class="tool-trust label mt-2 mb-8 max-w-2xl">{trust}</p>
  <slot />
  <div class="tool-explainer mt-12 border-t border-rule pt-6 max-w-2xl text-sm text-muted leading-relaxed">
    <slot name="explainer" />
  </div>
</div>
