---
import Base from '../../hubs/dev0/layouts/Base.astro';
import ToolLayout from '../../hubs/dev0/components/ToolLayout.astro';
---
<Base
  title=".env Inspector, 100% local | TabZero"
  description="Inspect .env syntax, duplicate keys, and quoted values without uploading secrets."
>
  <ToolLayout name=".env Inspector">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="rounded-sm border border-rule bg-raised overflow-hidden">
        <div class="px-4 py-2.5 border-b border-rule"><span class="label">.env contents</span></div>
        <textarea id="env-input" spellcheck="false" class="w-full h-64 p-4 bg-transparent text-sm font-mono text-ink resize-none focus:outline-none">API_URL=https://localhost:3000
FEATURE_FLAG=true
export CACHE_TTL=60</textarea>
      </div>
      <div class="rounded-sm border border-rule bg-raised overflow-hidden">
        <div class="px-4 py-2.5 border-b border-rule"><span class="label">Inspection</span></div>
        <pre id="env-output" class="min-h-64 p-4 overflow-x-auto whitespace-pre-wrap text-sm font-mono text-ink"></pre>
      </div>
    </div>
    <p slot="explainer">Paste an environment file to list parsed variables and flag malformed or duplicate keys. Secrets stay in your tab; this is a syntax aid, not a secret validator.</p>
  </ToolLayout>
</Base>
<script>
  import { envSection } from '../../hubs/dev0/scripts/tools/toolbox';
  envSection();
</script>
