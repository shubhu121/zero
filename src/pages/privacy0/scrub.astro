---
import Base from '../../hubs/privacy0/layouts/Base.astro';
import Header from '../../hubs/privacy0/components/Header.astro';
import Footer from '../../hubs/privacy0/components/Footer.astro';
import ToolLayout from '../../hubs/privacy0/components/ToolLayout.astro';
---
<Base title="PII Scrubber · privacy0" description="Detect and redact personally identifiable information from text. Review each match before applying.">
  <Header />
  <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-8">
    <ToolLayout name="PII Scrubber">
      <div slot="explainer">
        <p class="mb-2">Detects: email · phone · SSN · credit card (Luhn-validated) · Aadhaar (Verhoeff-validated) · PAN · IPv4 · IBAN. Earlier rule types win on overlapping matches.</p>
        <p>Click any highlight to toggle it. <code>[PLACEHOLDER-N]</code> assigns consistent labels per unique value; mask replaces with █ characters.</p>
      </div>

      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Input column -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-2">
            <label for="scrub-input" class="label">Paste text</label>
            <span class="ml-auto text-xs text-muted">
              <span id="pii-count" class="font-mono text-accent">0</span> redactions active
            </span>
          </div>
          <textarea
            id="scrub-input"
            rows="12"
            class="w-full font-mono text-sm border border-rule rounded p-3 bg-bg text-ink resize-y focus:outline-none focus:border-accent"
            placeholder="Paste text containing sensitive data here…"
          ></textarea>

          <div id="scrub-preview" class="mt-3 min-h-[3rem] font-mono text-sm border border-rule rounded p-3 bg-raised text-ink leading-relaxed whitespace-pre-wrap break-words"></div>
        </div>

        <!-- Sidebar -->
        <div class="lg:w-64 shrink-0">
          <p class="label mb-3">Detected PII</p>
          <div id="pii-sidebar" class="text-muted text-sm">Start typing to scan.</div>

          <div class="mt-6 space-y-3">
            <div>
              <label for="scrub-style" class="label mb-1 block">Redaction style</label>
              <select id="scrub-style" class="w-full border border-rule rounded px-3 py-1.5 text-sm bg-bg text-ink focus:outline-none focus:border-accent">
                <option value="placeholder">Placeholder [KIND-N]</option>
                <option value="mask">Mask ████</option>
              </select>
            </div>
            <button id="scrub-apply" class="btn w-full">Apply redactions</button>
            <button id="scrub-copy" class="btn-secondary w-full">Copy redacted</button>
          </div>
        </div>
      </div>
    </ToolLayout>
  </main>
  <Footer />
</Base>

<script>
  import { initScrub } from '../../hubs/privacy0/scripts/tools/scrub';
  initScrub();
</script>
