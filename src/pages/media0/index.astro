---
import Base from '../../hubs/media0/layouts/Base.astro';
import Header from '../../hubs/media0/components/Header.astro';
import Footer from '../../hubs/media0/components/Footer.astro';

const tools = [
  { href: '/media0/transcribe', name: 'transcribe', desc: 'Whisper speech-to-text with timestamps and SRT / VTT export', hero: true },
  { href: '/media0/convert', name: 'convert', desc: 'MP4 · WebM · MP3 · WAV', hero: false },
  { href: '/media0/compress', name: 'compress', desc: 'shrink an MP4 with adjustable quality', hero: false },
  { href: '/media0/trim', name: 'trim', desc: 'cut a clip — keyframe-fast or exact', hero: false },
  { href: '/media0/gif', name: 'video → gif', desc: 'high-quality two-pass palette GIFs', hero: false },
  { href: '/media0/extract-audio', name: 'extract audio', desc: 'pull the audio as MP3 / WAV / M4A', hero: false },
];
---
<Base
  title="media0 — transcribe & transcode in your browser, no uploads"
  description="Transcribe (Whisper), convert, trim, compress and GIF audio & video entirely on your device. FFmpeg and Whisper compiled to WebAssembly — nothing is uploaded, no API keys."
>
  <Header />
  <main class="suite-main flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-8">
    <div class="fade-in">
      <section class="max-w-2xl">
        <h1 class="display text-4xl sm:text-6xl tracking-tight leading-[1.05]">
          Your media. Your machine.<br />
          <span class="text-accent">No uploads.</span>
        </h1>
        <p class="mt-5 max-w-2xl text-muted leading-relaxed">
          Transcribe, convert, trim, compress and turn clips into GIFs — all in this tab. FFmpeg and
          Whisper are compiled to WebAssembly and run on your device, so even a 2-hour recording never
          leaves your laptop. No accounts, no API keys, no server.
        </p>
        <p class="label mt-5">100% client-side · 0 trackers · 0 cookies · verify in DevTools → Network</p>
      </section>

      <section class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-px bg-rule border border-rule rounded overflow-hidden">
        {tools.map((t, i) => (
          <a href={t.href} class:list={["group bg-bg p-5 hover:bg-raised transition-colors", t.hero && "sm:col-span-2", !t.hero && tools.filter((x) => !x.hero).length % 2 === 1 && i === tools.length - 1 && "sm:col-span-2"]}>
            <div class="flex items-baseline justify-between gap-2">
              <span class="font-semibold text-ink group-hover:text-accent transition-colors">
                {t.name}{t.hero && <span class="label text-accent ml-2">hero</span>}
              </span>
              <span class="label text-muted group-hover:text-accent transition-colors">→</span>
            </div>
            <p class="mt-1 text-sm text-muted leading-relaxed">{t.desc}</p>
          </a>
        ))}
      </section>

      <section class="mt-12 border-t border-rule pt-6 max-w-2xl text-sm text-muted leading-relaxed">
        <h2 class="label text-ink">How is this possible?</h2>
        <p class="mt-2">Browsers can now run heavy native tooling
        via WebAssembly. media0 loads FFmpeg.wasm (multithreaded where your browser is cross-origin
        isolated) and OpenAI's Whisper through Transformers.js — on WebGPU when available, WebAssembly
        otherwise. Everything executes locally; open DevTools → Network and watch the silence.</p>
      </section>
    </div>
  </main>
  <Footer />
</Base>
