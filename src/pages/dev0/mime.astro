---
import Base from '../../hubs/dev0/layouts/Base.astro';
import ToolLayout from '../../hubs/dev0/components/ToolLayout.astro';
---
<Base
  title="MIME Type Lookup, 100% local | TabZero"
  description="Look up common file extensions and MIME types locally in your browser."
>
  <ToolLayout name="MIME Type Lookup">
    <div class="max-w-2xl rounded-sm border border-rule bg-raised overflow-hidden">
      <div class="px-4 py-2.5 border-b border-rule"><span class="label">Filename or extension</span></div>
      <div class="p-4 border-b border-rule"><input id="mime-input" value="icons/logo.svg" class="w-full p-3 bg-bg text-lg font-mono text-ink border border-rule rounded-sm focus:outline-none focus:border-accent" aria-label="Filename or extension" /></div>
      <pre id="mime-output" class="min-h-40 p-4 whitespace-pre-wrap text-sm font-mono text-ink"></pre>
    </div>
    <p slot="explainer">A compact, built-in reference for common web file types. It does not send filenames or inspect local files.</p>
  </ToolLayout>
</Base>
<script>
  import { mimeSection } from '../../hubs/dev0/scripts/tools/toolbox';
  mimeSection();
</script>
