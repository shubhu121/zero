---
import Base from '../../hubs/dev0/layouts/Base.astro';
import ToolLayout from '../../hubs/dev0/components/ToolLayout.astro';
---
<Base
  title="Regex Tester - live highlighting, 100% local | dev0.dev"
  description="Test regular expressions with live match highlighting, capture groups and explanations. Your text never leaves the browser."
>
  <ToolLayout name="Regex Tester">
    <div class="space-y-4">
      <div class="rounded-sm border border-rule bg-raised overflow-hidden">
        <div class="px-4 py-2.5 border-b border-rule flex items-center gap-3">
          <span class="label">Pattern</span>
          <span class="text-muted font-mono text-sm">/</span>
          <input
            id="regex-pattern"
            type="text"
            class="flex-1 bg-transparent text-sm font-mono text-accent focus:outline-none placeholder:text-muted"
            placeholder="(\w+)@([\w.]+)"
          />
          <span class="text-muted font-mono text-sm">/</span>
          <input
            id="regex-flags"
            type="text"
            class="w-16 bg-transparent text-sm font-mono text-warn focus:outline-none placeholder:text-muted"
            placeholder="g"
            maxlength="6"
          />
        </div>
        <div id="regex-error" class="hidden px-4 py-2 bg-bg border-t border-err text-xs text-err font-mono"></div>
      </div>

      <div class="rounded-sm border border-rule bg-raised overflow-hidden">
        <div class="px-4 py-2.5 border-b border-rule flex items-center justify-between">
          <span class="label">Test String</span>
          <div class="flex items-center gap-3 text-[10px] text-muted">
            <span id="regex-match-count" class="font-mono">0 matches</span>
            <button id="regex-load-sample" class="text-accent hover:underline">Load sample</button>
          </div>
        </div>
        <textarea
          id="regex-input"
          class="w-full h-40 p-4 bg-transparent text-sm font-mono text-ink resize-y focus:outline-none placeholder:text-muted"
          placeholder="Paste text to test against the pattern above..."
        ></textarea>
      </div>

      <div class="rounded-sm border border-rule bg-raised overflow-hidden">
        <div class="px-4 py-2.5 border-b border-rule">
          <span class="label">Highlighted Matches</span>
        </div>
        <div id="regex-output" class="p-4 text-sm font-mono text-ink whitespace-pre-wrap break-words min-h-[100px]">
          <span class="text-muted">Matches will appear here as you type.</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-sm border border-rule bg-raised overflow-hidden">
          <div class="px-4 py-2.5 border-b border-rule">
            <span class="label">Capture Groups</span>
          </div>
          <div id="regex-groups" class="p-4 text-xs font-mono text-muted min-h-[60px]">—</div>
        </div>
        <div class="rounded-sm border border-rule bg-raised overflow-hidden">
          <div class="px-4 py-2.5 border-b border-rule">
            <span class="label">Explanation</span>
          </div>
          <div id="regex-explain" class="p-4 text-xs font-mono text-muted min-h-[60px]">—</div>
        </div>
      </div>
    </div>

    <p slot="explainer">
      Type a JavaScript regular expression and test string to see every match
      highlighted live, with capture groups and a token-by-token explanation of the
      pattern. It uses your browser's own RegExp engine, so behaviour matches what
      your JS code will do. The text you paste stays in this tab.
    </p>
  </ToolLayout>
</Base>
<script>
  import { regexSection } from '../../hubs/dev0/scripts/tools/regex';
  regexSection();
</script>
